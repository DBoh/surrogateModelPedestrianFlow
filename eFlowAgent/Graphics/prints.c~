#include <ped.h>


//! prints a sparce matrix A in MxM-format to bla
void PrintSparceMatrix(REAL *A, int M, char *bla)
{
  int i, j, ij;
  char notext[1];
  REAL *u, *v;
  FILE *fp;

  u = (REAL *)calloc(M , sizeof(REAL ));
  v = (REAL *)calloc(M , sizeof(REAL ));

  notext[0] = '\0';

  fp=fopen(bla,"w");

  for(i=0 ; i<M ; i++){
    // u Null setzen
    field_cp(u,0.,u,0.,u,0.,M);

    u[i] = 1;

    amul(A,u,v);

    for(j=0 ; j<M ; j++)
      fprintf(fp,"%7.3e ",v[j]);
    fprintf(fp,"\n");

    if(M<=20){
      for(j=0 ; j<M ; j++)
  printf("%7.3e ",v[j]);
      printf("\n");
    }

  }
  fprintf(fp,"\n");
  fclose(fp);


  free(u);
  free(v);
}

