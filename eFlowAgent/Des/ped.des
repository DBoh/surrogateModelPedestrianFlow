/*!
	\fn PED_bound()
 	\brief maps every node to wall-, entree- or exit-boundary
  
	\f[{\rm node[i].id}=\left\{\begin{array}{ll}
	  -2 & {\rm if}\quad x_i\in \Gamma_W\\
	    -2\,k-4& {\rm if}\quad x_i\in \Gamma_{E_k}\\
	      -2\,k-5 & {\rm if}\quad  x_i\in\Gamma_{A_k}\\
	        i & {\rm if}\quad  x_i\in\Omega\setminus\partial\Omega
		    \end{array}\right.
  		    \f]
 */

/*!
  \fn ChkEntree(int i)
  \brief check if node is part of the entree
  
  \f[{\rm ChkEntree}(i)=\left\{\begin{array}{ll}
  j+1 & {\rm if}\quad x_i\in\Gamma_{E_j}\,,~j=0,\ldots,{\rm numentree}\\
  0 & {\rm elsewhere}
  \end{array}\right.\f]
*/

/*!
  \fn ChkExit(int i)
  \brief check if node is part of the entree

  \f[{\rm ChkExit}(i)=\left\{\begin{array}{ll}
  j+1 & {\rm if}\quad x_i\in\Gamma_{A_j}\,,~j=0,\ldots,{\rm numexit}\\
  0 & {\rm elsewhere}
  \end{array}\right.\f]
*/

