void ParamInit(REAL *rho)
{
  int i, l;
  REAL h=refine.gridwidth, hfd, fdv, GE, PFD;
  REAL Door[4], fdmax=1, SumExit, EntreePerCent[2];
  char msg[100];
  FILE *fp;


  EntreePerCent[0]=100; EntreePerCent[1]=100;
  
  if (PED.EPS1<0.)
    PED.EPS1 = pow(h,11./16.);
  if (PED.EPS0<0.)
    PED.EPS0 = h*h;
  if (PED.delta<0.)
    PED.delta = h*h;

  #if MSG
  sprintf(msg,"%e",PED.EPS0);
  Message("EPS0=",'=',msg);
  #endif

  PED.FDnk = ReadFDData(PED.FDname,1.0);
  hfd = 1./(PED.FDnk-1);


#if PLOT
  fp=fopen("00Output/Fundamentaldiagram.dat","w");
  for(i=0 ; i<PED.FDnk ; i++){
    fdv = FD_Value(hfd*i,0,0.,0.,0);
    fprintf(fp,"%f %f %f\n",hfd*i,fdv,hfd*i*fdv);
    if(hfd*i*fdv>fdmax) fdmax=hfd*i*fdv;
  }
  fclose(fp);
#endif
  
  for(i=0 ; i<PED.numentree ; i++){
    for(l=0 ; l<4 ; l++)
      Door[l] = PED.entree[l][i];

    GE = sqrt(pow(Door[0]-Door[2],2.)+pow(Door[1]-Door[3],2.));
    PFD = PED.pFlowDoor[i]; 
    //    PED.RhoInflow[i] = CurrentDensity(Door,PFD,1);


    if(fdmax<PED.pFlowDoor[i]){
      sprintf(msg,"EntreePersons too large at Door %d: allowed: %f",
        i,fdmax*PED.CP*PED.CV*PED.CL*PED.CT*GE);
      ErrorMessage(msg,"ped_init");
    }

  }


  if(PED.numexit==0) ErrorMessage("No exit chosen","ParamInit");

  
  for(i=0 ; i<PED.numexit ; i++){
    SumExit=0.;
    for(l=0 ; l<4 ; l++)
      Door[l] = PED.exit[l][i];

    SumExit += sqrt(pow(Door[0]-Door[2],2.)+pow(Door[1]-Door[3],2.));
  }


  if(SumExit<EpsZero) ErrorMessage("No exit chosen II","ParamInit");

  
  //  siragent.CD += PED.Shoulder;
  siragent.CD /= PED.CL;


}



