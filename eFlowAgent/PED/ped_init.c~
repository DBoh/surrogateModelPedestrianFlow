void RhoInitSubdomainsRand(REAL *rho, int *PnumT, REAL *TXY[2])
{
  int i, l, Pcount, k, loop=0;
  int SDNr, *SDNrSum, *SetDec;
  REAL xt[2];

  SetDec   = (int *)calloc(RhoIni.NumSubdom , sizeof(int ));
  SDNrSum  = (int *)calloc(RhoIni.NumSubdom , sizeof(int ));
  SetDecomposition(PED.Pinit,RhoIni.NumSubdom,SetDec); // hier noch Anteil je Flaeche

  Pcount=0; loop=0; k=0;
  while(Pcount<PED.Pinit){
    k = min(max(0,round(NT*(REAL)(rand())/RAND_MAX)),NT-1);

    if(RhoIni.Tvec[k]>0.8){ // also eigentlich 1...., wenn T ganz im Subdom enthalten ist

      SDNr = RhoIni.KnotToSubdom[tri[k].VNR[0]]; // no of actual subdom
      if(SDNrSum[SDNr]<SetDec[SDNr]){ // Dreieck noch nicht mit der Teilmenge gefuellt

        TriRandXY(k,xt);
        for(l=0 ; l<2 ; l++)
          TXY[l][Pcount] = xt[l];
        
        Pcount++;        // alle gesetzten Tracks
        SDNrSum[SDNr]++; // gesetzte Tracks je Subdom
        PnumT[k]++;      // Zaehler fuer Tracks je Dreieck

      }
    }

    if(loop++>=100000)
      ErrorMessage("something wrong","RhoInitSubdomainsRand");

  }
  
  free(SetDec);
  free(SDNrSum);

}

