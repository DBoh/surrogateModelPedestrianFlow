void RhoInit(REAL *rho)
{
  int i, l, k;
  int *PnumT;
  REAL TM, *TXY[2], xt[2], Rhomax, tau, OM, SM;

  VideoInit();

  for(l=0 ; l<2 ; l++)
    TXY[l] = (REAL *)calloc(video.TrackPersonMax , sizeof( REAL ));
  PnumT    = (int *)calloc(NT , sizeof(int ));

  FieldCp(rho,1.,RhoIni.Kvec,0.,NK);
  
  if(RhoIni.NumSubdom){
    if(!PED.Prand)
      RhoInitSubdomainsConst(rho,PnumT,TXY);
    else 
      RhoInitSubdomainsRand(rho,PnumT,TXY);
  } else {
    if(!PED.Prand)
      RhoInitNoSubdomainsConst(rho,PnumT,TXY);
    else 
      RhoInitNoSubdomainsRand(rho,PnumT,TXY);
  }

  /* Skalierung auf */

  if(PED.Prand)
    {
      Rhomax=0.;
      for(k=0 ; k<NT ; k++){
	for(l=0 ; l<3 ; l++){
	  i = tri[k].VNR[l];
	  rho[i] += PnumT[k]/3.;
	  if(Rhomax<rho[i]) Rhomax = rho[i];
	}
      }
    }
  

  Rhomax = FieldMax(rho,NK);
  if(Rhomax>1) FieldCp(rho,1./Rhomax,rho,0.,NK);
  TM = TotalMass(MAT.Mass,rho);
  SM = TotalMass(MAT.Mass,RhoIni.Kvec); 

  if(PED.Pinit*Rhomax/TM<1)
    for(i=0 ; i<NK ; i++)
      rho[i] *= PED.Pinit/TM;
  else
    {
      tau = (PED.Pinit-TM)/(SM-TM);

      for(i=0 ; i<NK ; i++)
	if(RhoIni.Kvec[i]>0)
	  rho[i] = (1-tau)*rho[i]+tau;
    }


#if TP
  for(i=0 ; i<video.TrackPerson ; i++)
    for(l=0 ; l<2 ; l++)
      video.TrackXYPosition[l][i] = TXY[l][i];
#endif

#if SIRA
  sir_agent_init();
#endif

#if PLOT    
  WriteTrackPoints(rho,"TrackPoints_i_x_y_rho",0);
#endif

  free(PnumT);
  for(l=0 ; l<2 ; l++)
    free(TXY[l]);

}

