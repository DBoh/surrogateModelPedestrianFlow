void RhoInitNoSubdomainsRand(REAL *rho, int *PnumT, REAL *TXY[2])
{
  int i, l, Pcount, k, loop=0;
  REAL TM, xt[2];

  Pcount=0; loop=0; k=0;
  while(Pcount<PED.Pinit){
    k = min(max(0,round(NT*(REAL)(rand())/RAND_MAX)),NT-1);
      
    TriRandXY(k,xt);
    for(l=0 ; l<2 ; l++)
      TXY[l][Pcount] = xt[l];
	
    Pcount++;        // alle gesetzten Tracks
    PnumT[k]++;      // Zaehler fuer Tracks je Dreieck

    if(loop++>=100000)
      ErrorMessage("something wrong","RhoInitNoSubdomainsRand");

  }
  
}

