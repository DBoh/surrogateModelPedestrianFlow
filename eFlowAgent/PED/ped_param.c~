void ReadTriangle(int NT, FILE *fp)
{
  int tmin = 100, i, l;
  char linebuf[100];

  tri = (GE *)malloc(NT * sizeof(GE));
  for (i = 0; i < NT; i++)
  {
    fgets(linebuf, sizeof(linebuf), fp);
    sscanf(linebuf, "%d %d %d", &tri[i].VNR[0], &tri[i].VNR[1], &tri[i].VNR[2]);
    for (l = 0; l < 3; l++)
      if (tri[i].VNR[l] < tmin)
        tmin = tri[i].VNR[l];
  }

  if (tmin == 1)
    for (i = 0; i < NT; i++)
      for (l = 0; l < 3; l++)
        tri[i].VNR[l]--;
}

/******************************************************************************************/
void ReadXY(int NK, FILE *fp)
{
  int i;
  REAL xx, yy;
  char linebuf[100];

  XY = (REAL *)malloc(2 * NK * sizeof(REAL));
  for (i = 0; i < NK; i++)
  {
    fgets(linebuf, sizeof(linebuf), fp);
    sscanf(linebuf, "%lf %lf", &xx, &yy);
    XY[2 * i] = xx;
    XY[2 * i + 1] = yy;
  }
}

/******************************************************************************************/
void ReadEntree(FILE *fp)
{
  int l, ll;
  REAL pe[4];
  char linebuf[100];

  fgets(linebuf, sizeof(linebuf), fp);

  if (NoInput(linebuf))
  {
    PED.numentree = 0;
  }
  else
  {
    sscanf(linebuf, "%d ", &PED.numentree);
  }

  for(l=0 ; l<4 ; l++)
    PED.entree[l] = (REAL *)calloc(PED.numentree , sizeof(REAL ));
  
  PED.EntreePersons = (REAL *)calloc(PED.numentree , sizeof(REAL ));
  //  PED.RhoInflow = (REAL *)calloc(PED.numentree , sizeof(REAL ));
  PED.MaxEntreePersons = (REAL *)calloc(PED.numentree , sizeof(REAL ));
  PED.pFlowDoor = (REAL *)calloc(PED.numentree , sizeof(REAL ));
  PED.DensityDoor = (REAL *)calloc(PED.numentree , sizeof(REAL ));
  PED.MaxTimeDoor = (REAL *)calloc(PED.numentree , sizeof(REAL ));


  for (l = 0; l < PED.numentree; l++)
  {
    fgets(linebuf, sizeof(linebuf), fp);
    sscanf(linebuf, "%lf %lf %lf %lf %lf %lf", &pe[0], &pe[1], &pe[2], &pe[3], &PED.EntreePersons[l], &PED.MaxEntreePersons[l]);
    for (ll = 0; ll < 4; ll++)
      PED.entree[ll][l] = (REAL)pe[ll];

    if (PED.EntreePersons[l] > 0)
      PED.MaxTimeDoor[l] = PED.MaxEntreePersons[l] / PED.EntreePersons[l];
    else
      PED.MaxTimeDoor[l] = PED.MaxTime;
  }
}

/******************************************************************************************/
void ReadExit(FILE *fp)
{
  int l, ll;
  REAL pe[4];
  char linebuf[100];

  fgets(linebuf, sizeof(linebuf), fp);
  if (NoInput(linebuf))
  {
    PED.numexit = 0;
  }
  else
  {
    sscanf(linebuf, "%d ", &PED.numexit);
  }

  for (l = 0; l < 4; l++)
    PED.exit[l] = (REAL *)calloc(PED.numexit, sizeof(REAL));
  PED.ExitAttraction = (REAL *)calloc(PED.numexit, sizeof(REAL));

  for (l = 0; l < PED.numexit; l++)
  {
    fgets(linebuf, sizeof(linebuf), fp);

    sscanf(linebuf, "%lf %lf %lf %lf %lf", &pe[0], &pe[1], &pe[2], &pe[3], &PED.ExitAttraction[l]);
    for (ll = 0; ll < 4; ll++)
      PED.exit[ll][l] = (REAL)pe[ll];

    PED.ExitAttraction[l] = min_REAL(1, max_REAL(0, PED.ExitAttraction[l]));
  }
}

/******************************************************************************************/
void ReadSubdomRhoini(FILE *fp)
{
  int l, i;
  char linebuf[100];

  fgets(linebuf, sizeof(linebuf), fp);
  if (NoInput(linebuf))
  {
    sprintf(refine.subdomainRhoini, "empty");
    RhoIni.NumSubdom = 0;
  }
  else
  {
    sscanf(linebuf, "%d", &RhoIni.NumSubdom); // Anzahl Subdomains
    RhoIni.P = (POLY *)malloc(RhoIni.NumSubdom * sizeof(POLY));

    RhoIni.PKmax = 0;
    for (l = 0; l < RhoIni.NumSubdom; l++)
    {
      fscanf(fp, "%d", &RhoIni.P[l].NumK);
      RhoIni.P[l].XY = (REAL *)calloc(2 * RhoIni.P[l].NumK, sizeof(REAL));
      if (RhoIni.PKmax < RhoIni.P[l].NumK)
        RhoIni.PKmax = RhoIni.P[l].NumK;
    }

    for (l = 0; l < RhoIni.NumSubdom; l++)
      for (i = 0; i < RhoIni.P[l].NumK; i++)
        fscanf(fp, "%lf %lf", &RhoIni.P[l].XY[2 * i], &RhoIni.P[l].XY[2 * i + 1]);

    fgets(linebuf, sizeof(linebuf), fp); // Rest der Zeile einlesen
  }
}

