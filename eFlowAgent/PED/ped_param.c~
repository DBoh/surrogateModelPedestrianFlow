/******************************************************************************************/
void ReadPolygon(FILE *fp)
{
  int l, i;
  char linebuf[100];
  REAL xx;

  fgets(linebuf,sizeof(linebuf),fp);
  if(NoInput(linebuf))
    {
      DomainPoly.NumK = 0;
      DomainPoly.NumS = 0;
      DomainPoly.NumH = 0;
    }
  else
    {
      sscanf(linebuf,"%d",&DomainPoly.NumK); // Anzahl aller Polygonknoten
      DomainPoly.XY = (REAL *)calloc(2*DomainPoly.NumK , sizeof(REAL ));

      for(l=0 ; l<2*DomainPoly.NumK ; l++)
	fscanf(fp,"%lf",&DomainPoly.XY[l]);

      fscanf(fp,"%d",&DomainPoly.NumS); // Anzahl aller Segmente
      DomainPoly.SEG = (int *)calloc(2*DomainPoly.NumS , sizeof(int ));

      for(l=0 ; l<2*DomainPoly.NumS ; l++)
	fscanf(fp,"%d",&DomainPoly.SEG[l]);
	
      fscanf(fp,"%d",&DomainPoly.NumH); // Anzahl aller Loecher

      if(DomainPoly.NumH>0){
	DomainPoly.HOLES = (REAL *)calloc(2*DomainPoly.NumH , sizeof(REAL ));

	for(l=0 ; l<2*DomainPoly.NumH ; l++)
	  fscanf(fp,"%lf",&DomainPoly.HOLES[l]);
      }
      fscanf(fp,"%lf %d %d",&DomainPoly.Granu,&refine.lg,&refine.ll);
      fgets(linebuf,sizeof(linebuf),fp);
    }
}

