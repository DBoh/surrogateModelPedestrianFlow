void ReadGrid(FILE *fp)
{
  char linebuf[100];

  fgets(linebuf,sizeof(linebuf),fp);
  
  if(!DomainPoly.NumK && !NoInput(linebuf)){
    sscanf(linebuf,"%d %d %d %d",&NK,&NT,&refine.lg,&refine.ll);

    ReadTriangle(NT,fp); // read triangles
    ReadXY(NK,fp);       // read knotes
  }

  if(!DomainPoly.NumK && NoInput(linebuf))
    ErrorMessage("Needs Polygon or Domaingrid","ReadGrid");
  
    
}


