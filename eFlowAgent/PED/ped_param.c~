void AskForComment(char *buf, char *text)
{
  if (strncmp(buf, "##", 2))
    ErrorMessage("no comment", text);
}

/******************************************************************************************/
int NoInput(char *buf)
{
  if (!strncmp(buf, "empty", 5))
    return 1;
  return 0;
}

int fps_check(int loop, REAL delta, REAL fps)
{
  int n;
  n = max(round(1 / delta / fps), 1);
  if (loop % n == 0)
    return 1;
  else
    return 0;
}



void ExitEntranceCorrection()
{
  int i, out;
  REAL s1x, s1y, s2x, s2y;
  char msg[100];

#if MSG
  WriteLog("Exit Orientations/Corrections","a");
#endif
  
  for(i=0 ; i<PED.numexit ; i++)
    {
      s1x = PED.exit[0][i]; s1y = PED.exit[1][i];
      s2x = PED.exit[2][i]; s2y = PED.exit[3][i];

      out = SegToDomainBoundMagnet(&s1x,&s1y,&s2x,&s2y);

      PED.exit[0][i] = s1x; PED.exit[1][i] = s1y;
      PED.exit[2][i] = s2x; PED.exit[3][i] = s2y;

#if MSG
      sprintf(msg,"Exit_%d Orientation: %d",i,out);
      WriteLog(msg,"a");
#endif
    }

#if MSG
  if(PED.numentree)
    WriteLog("Entrance Orientations/Corrections","a");
#endif

  for(i=0 ; i<PED.numentree ; i++)
    {
      s1x = PED.entree[0][i]; s1y = PED.entree[1][i];
      s2x = PED.entree[2][i]; s2y = PED.entree[3][i];

      out = SegToDomainBoundMagnet(&s1x,&s1y,&s2x,&s2y);

      PED.entree[0][i] = s1x; PED.entree[1][i] = s1y;
      PED.entree[2][i] = s2x; PED.entree[3][i] = s2y;

#if MSG
      sprintf(msg,"Entrance_%d Orientation: %d",i,out);
      WriteLog(msg,"a");
#endif
    }

}
