void ReadConfigFile()
{
  int jsonfile=0;
  char linebuf[100], fend[100], msg[100], blac, bla[]=" ";
  FILE *fp;
  char LeftParanthesis[]="{";

  
  fp = fopen("00Input/eFlow.dat", "r");
  if (!fp)
    ErrorMessage("Can't open file eFlow.dat", "ReadEflowParam");

  fgets(linebuf, sizeof(linebuf), fp);
  sscanf(linebuf, "%s", PED.ConfigFile);
  fclose(fp);

  
  fp = fopen(PED.ConfigFile, "r");
  if (!fp)
    ErrorMessage("Can't open ConfigFile", "ReadEflowParam");

  blac = fgetc(fp);
  sprintf(bla,"%c",blac);

  if(!strcmp(bla,LeftParanthesis))
    jsonfile = 1;

  fclose(fp);

  if(!jsonfile)
    {
      ReadEflowParam();
      //      WriteEflowFile("00Input/json_e.eflow");
    }
  else 
    {
      ReadJsonParam();
      //      WriteEflowFile("00Input/json_j.eflow");
    }


  if(DomainPoly.NumK) // falls Grid, dann gibt es das Polygon nicht
    {
      DomainPoly.PolyNo = (int *)calloc(DomainPoly.NumK , sizeof(int ));
      Dpoly = (POLY *)malloc((DomainPoly.NumH+1) * sizeof(POLY ));
      
      DomainPolygonsAndOrientations();
      ExitEntranceCorrection();
    }  

}

