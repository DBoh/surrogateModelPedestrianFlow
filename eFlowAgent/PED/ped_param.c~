/******************************************************************************************/
void ReadAttractors(FILE *fp)
{
  int l;
  char linebuf[100];
  time_t ttt;

  srand((unsigned)time(&ttt));

  fgets(linebuf, sizeof(linebuf), fp);
  if (!NoInput(linebuf))
  {
    sscanf(linebuf, "%d", &PED.AS);

    for (l = 0; l < 7; l++)
      PED.ASx[l] = (REAL *)calloc(PED.AS, sizeof(REAL));
    PED.ASphi = (REAL *)calloc(PED.AS, sizeof(REAL));

    for (l = 0; l < PED.AS; l++)
    {
      fgets(linebuf, sizeof(linebuf), fp);
      sscanf(linebuf, "%lf %lf %lf %lf %lf %lf %lf", &PED.ASx[0][l], &PED.ASx[1][l], &PED.ASx[2][l], &PED.ASx[3][l], &PED.ASx[4][l], &PED.ASx[5][l], &PED.ASx[6][l]);

      PED.ASx[5][l] /= PED.CL;
      PED.ASx[4][l] = min_REAL(max_REAL(-1., PED.ASx[4][l]), 1.);
    }

    for (l = 0; l < PED.AS; l++)
      if (fabs(PED.ASx[6][l]) > EpsZero)
        PED.ASphi[l] = (REAL)(rand()) / RAND_MAX / PED.ASx[6][l];
  }
  else
    PED.AS = 0;
}

/******************************************************************************************/
void ReadPEDModelParam(FILE *fp)
{
  int l;
  char linebuf[100];

  fgets(linebuf, sizeof(linebuf), fp);
  sscanf(linebuf, "%lf", &PED.CL);
  fgets(linebuf, sizeof(linebuf), fp);
  sscanf(linebuf, "%lf", &PED.CP);

  fscanf(fp, "%d", &SDCV.NumSubdom);
  fscanf(fp, "%lf", &PED.CV);

  if(SDCV.NumSubdom)
    {
      PED.CVsd = (REAL *)calloc(SDCV.NumSubdom , sizeof(REAL));
  
      for (l = 0; l < SDCV.NumSubdom ; l++)
	fscanf(fp, "%lf", &PED.CVsd[l]);
    }
  
  fgets(linebuf, sizeof(linebuf), fp); // rest of line...
  fgets(linebuf, sizeof(linebuf), fp);
  sscanf(linebuf, "%d", &PED.Pinit);
  if(PED.Pinit<0)
    {
      PED.Prand = 0;
      PED.Pinit = -PED.Pinit;
    }
  else
    PED.Prand=1;
  
  fgets(linebuf, sizeof(linebuf), fp);
  sscanf(linebuf, "%lf", &PED.MaxTime);
}

