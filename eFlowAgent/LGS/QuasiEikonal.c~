/*!
  \file QuasiEikonal.c
  \brief an alternative for the eikonal equation
*/
#include <ped.h>

extern REAL EpsZero, EpsReg;
extern GN *node;
extern int NT, NK;
extern GE *tri;
extern DAT PED;

REAL RhoWeight(REAL *r, int k)
{
  int l;
  REAL rm=0.;

  for(l=0 ; l<3 ; l++)
    rm += r[tri[k].VNR[l]]/10.;

  return rm;
}

void ExitDist(int k, REAL *rho, REAL *Flag, REAL edist)
{
  int l, kl;
  REAL dist;

  for(l=0 ; l<3 ; l++)
    {
      kl = tri[k].NEIGH[l];
      if(Flag[kl]<0 || Flag[kl]>edist)
	{
	  Flag[kl] = edist;
	  dist = gridwidth_loc(kl); // area(kl);
	  dist += RhoWeight(rho,kl);
	  ExitDist(kl,rho,Flag,edist+dist);
	}
    }
}

void QuasiEikonalEquation(int LOOP, REAL *rho, REAL *vel[2],REAL *v)
{
  int k, l, ll, count,ne;
  int *NodeCount, *StartTri;
  REAL *TriDistFlag, *NodeDist, dist;

  NodeDist = (REAL *)calloc(NK , sizeof(REAL ));
  TriDistFlag = (REAL *)calloc(NT , sizeof(REAL ));
  StartTri = (int *)calloc(NT , sizeof(int ));
  NodeCount = (int *)calloc(NK , sizeof(int ));
  
  FieldCp(TriDistFlag,0.,TriDistFlag,-1.,NT);
  
  for(k=0 ; k<NT ; k++)
    {
      count = 0;
      for(l=0 ; l<3 ; l++)
	{
	  ll = tri[k].VNR[l];
	  if(ChkExit(ll))
	    {
	      ne=ChkExit(ll);
	      count++;
	    }
	  NodeCount[ll]++;
	}
      if(count>=2)
	{
	  // v[i] = PED.ExitAttraction[ne-1]*(1-PED.VMin)+PED.VMin;

	  TriDistFlag[k] = max_REAL(0.,1-PED.ExitAttraction[ne-1]);
	  //	  printf("Exit %d: %f \n",ne,TriDistFlag[k]);
	  StartTri[k] = 1;
	}
    }


  for(k=0 ; k<NT ; k++)
    {
      //      if(fabs(TriDistFlag[k])<EpsZero)
      if(StartTri[k])
	{
	  dist = gridwidth(k); // area(k)
	  dist += RhoWeight(rho,k);
	  ExitDist(k,rho,TriDistFlag,dist);
	}
    }

  
  /*____________________________________________________-
  
     fuer den plot 

  */
  REAL du[2], bv;
  int i;
  
  for(k=0 ; k<NT ; k++)
    {
      for(l=0 ; l<3 ; l++)
	{
	  ll = tri[k].VNR[l];
	  /*
	  if(ne=ChkExit(ll))
	    NodeDist[ll] = PED.ExitAttraction[ne-1];
	    else*/
	    NodeDist[ll] += TriDistFlag[k]/NodeCount[ll];
	}
    }

  for(ll=0 ; ll<NK ; ll++)
    v[ll] = exp(-NodeDist[ll]/PED.EPS1);

  for(k=0 ; k<NT ; k++)
    {
      duh(du,k,NodeDist);
      for(l=0 ; l<2 ; l++)
	for(i=0 ; i<3 ; i++)
	  {
	    ll = tri[k].VNR[i];
	    vel[l][ll] -= du[l]/NodeCount[ll];
	  }
    }

  for(i=0 ; i<NK ; i++)
    {
      bv = sqrt(vel[0][i]*vel[0][i]+vel[1][i]*vel[1][i]+EpsReg*EpsReg);
      for(l=0 ; l<2; l++)
	vel[l][i] /= bv;
    }
  
#if PLOT==2
  octaveplot(NodeDist,"QEPhi",0.,1.,LOOP);
  octaveplotvec(vel,"QEVel",LOOP);
#endif
  

  free(NodeDist);
  free(TriDistFlag);
  free(NodeCount);
  free(StartTri);
}
