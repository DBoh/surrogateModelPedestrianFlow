void amul_EOC(REAL *A, REAL *x, REAL *y)
{
  int i, k;

#if EOC
  for(i=0 ; i<NK ; i++){
    if(fabs(y-0.5)<EpsZero){
      y[i] = x[i];
    } else {
      y[i] = A[node[i].pointmat]*x[i];

      for(k=node[i].pointmat+1 ; k<node[i+1].pointmat ; k++)
	y[i] += A[k]*x[nach[k]];
    }
  }
#else
  amul(A,x,y);
#endif
  
}






