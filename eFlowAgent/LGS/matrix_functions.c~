#include <ped.h>

extern SOLV solver;
extern int NK, *nach;
extern GN *node;


/*!
  \brief Matrix-Vector Multiplication

  \f[A\,x=y\f]
*/
void amul(REAL *A, REAL *x, REAL *y)
{
  int i, k;

  for(i=0 ; i<NK ; i++){
    y[i] = A[node[i].pointmat]*x[i];

    for(k=node[i].pointmat+1 ; k<node[i+1].pointmat ; k++){
      y[i] += A[k]*x[nach[k]];
    }
  }

}

void amul_bd_exit(REAL *A, REAL *x, REAL *y)
{
  int i, k;
