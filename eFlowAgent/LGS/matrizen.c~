/*!
  \file matrizen.c
  \brief matrices of the system
*/
#include <ped.h>

extern Basis phi;
extern GE *tri;
extern int NT, NK, *nach, bandwidth;
extern REAL *XY;
extern GN *node;
extern MATRIX MAT;
extern DAT PED;
extern NEUTRALS ZO;

void SysMatrixV(REAL *Mat, REAL *v, void (*FuncElem)(REAL [6][6], int , REAL *))
{
  int i, mi, j, k, ig, jg, l;
  REAL LocInt[6][6];

  // diagnal_i, node[i].NEIGH_NODE[0] Eintraege,
  // diagonal_(i+1), node[i+1].NEIGH_NODE[0] Eintrage, ..

  for(k=0 ; k<NK*bandwidth ; k++)
    Mat[k]=0.;


  for(k=0 ; k<NT ; k++){
    FuncElem(LocInt,k,v);

    for(i=0 ; i<3 ; i++){
      ig = tri[k].VNR[i];
      mi = node[ig].pointmat;
      for(j=0 ; j<3 ; j++){
	jg = tri[k].VNR[j];

	if(i==j)
	  Mat[mi] += LocInt[i][i];
	else {
	  for(l=mi+1 ; l<node[ig+1].pointmat ; l++)
	    if(jg==nach[l])
	      Mat[l] += LocInt[i][j];
	}
      }
    }
  }
}


