void BoundIntegral(REAL *KB, REAL *v,int NumDoors, REAL *Door[4])
{
  int k, i, j, ld, l, j1, j2, ll, ig, jg, mi;
  REAL a1, a2, b1, b2, c1, c2, d1, d2;
  REAL MB[6][6], p[2], q[2];

  for(k=0 ; k<NK*bandwidth ; k++)
    KB[k] = 0.;

  for(k=0 ; k<NT ; k++){

    for(ll=0 ; ll<3 ; ll++){

      if(tri[k].NEIGH[ll]<0){
	j1 = tri[k].VNR[(ll+1)%3];
	j2 = tri[k].VNR[(ll+2)%3];


	c1 = XY[2*j1]; c2 = XY[2*j1+1];
	d1 = XY[2*j2]; d2 = XY[2*j2+1];

	for(ld=0 ; ld<NumDoors ; ld++){
	  
	  a1 = Door[0][ld]; a2 = Door[1][ld];
	  b1 = Door[2][ld]; b2 = Door[3][ld];

	  if(IntersectionSegment(a1,a2,b1,b2,c1,c2,d1,d2,&p[0],&p[1],&q[0],&q[1])){
	    mass_elem_b_v_loc(MB,k,ll,v,p,q);

	    for(i=0 ; i<3 ; i++){
	      ig = tri[k].VNR[i]; //j1, j2
	      mi = node[ig].pointmat; //j1, j2
	      for(j=0 ; j<3 ; j++){
		jg = tri[k].VNR[j];
		
		if(i==j)
		  KB[mi] += MB[i][i];
		else {
		  for(l=mi+1 ; l<node[ig+1].pointmat ; l++)
		    if(jg==nach[l])
		      KB[l] += MB[i][j];
		}
	      }
	    }
	    
	  } // endif intersection
	} // endif numdoors
      } // if Randdreieck
    } // for l
  } // for k
}

