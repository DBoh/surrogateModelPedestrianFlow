#include "../includes/ped.h"

extern int NT, NK;
extern GE *tri;
extern Basis phi;
extern REAL *XY;
extern DATA daten;
extern GN *node;
extern QUADRATUR QUAD;
extern MATRIX MAT;

// f = fac*M*f
void rhsvec(REAL *f, REAL fac)
{
  int i;
  REAL *ff;

  ff = (REAL *)calloc( NK , sizeof(REAL));
  amul(MAT.Mass,f,ff);

  for(i=0 ; i<NK ; i++)
    f[i] = ff[i]*fac;

  free(ff);
}

void rhs_vec(REAL *f, REAL fac)
{
  int i;
  REAL *fe;

  fe = (REAL *)calloc( NK , sizeof(REAL));
  fexact(fe);
  amul(MAT.Mass,fe,f);

  for(i=0 ; i<NK ; i++)
    f[i] *= fac;

  free(fe);
}

void rhs_ex(REAL *f, REAL fac)
{
  int i, j, l, ll, k, m, mm;
  REAL ut[2], st[3]={1./6.,2./3.,1./6.}, xd[2], x[2], det;
  REAL sum[2], y[2];

  for(j=0 ; j<NK ; j++)
    for(l=0 ; l<2 ; l++)
      f[j] = 0.;


  for(k=0 ; k<NT ; k++){
    det = detk(k);

    for(l=0 ; l<3 ; l++){
      j = tri[k].VNR[l];

      for(ll=0 ; ll<2 ; ll++)
  sum[ll]=0.;

      for(m=0 ; m<3 ; m++){
  mm=2-m;
  xd[0] = st[mm%3];
  xd[1] = st[(mm+1)%3];
  transform2_point(xd,k,x);

  for(ll=0 ; ll<2 ; ll++){
    y[ll] = 1.;
    sum[ll] += y[ll]*phi.value[l][m]*QUAD.w_2d[m]*det;
  }


      }

      for(ll=0 ; ll<2 ; ll++)
  f[j] += sum[ll];

    }
  }

  for(j=0 ; j<NK ; j++)
    for(l=0 ; l<2 ; l++)
      f[j] *= fac;

}


void fexact(REAL *f)
{
  int i;

  for(i=0 ; i<NK ; i++)
    f[i] = f_ex(XY[2*i],XY[2*i+1]);

}


// -Lu = f
REAL f_ex(REAL x, REAL y)
{
  REAL out=0, dummy;

  switch (daten.init){
  default:
    out = 0;
    break;
  case 3:
    out = -4.;
    break;
  case 4:
    out = -6.*(x + y);
    break;
  case 5:
    out = -200.*sin(10*x)*cos(10*y);
    break;
  }

  return out;
}

void bound2vec(REAL time, REAL *f, int flag)
{
  int i;

  switch (flag){
  case 0:
    // Dirchlet Null:
    for(i=0 ; i<NK ; i++)
      if(node[i].id==-2)
  f[i] = 0.;

    break;
  case 1:
    // Dirichlet u_ex:
    for(i=0 ; i<NK ; i++){
      if(node[i].id==-2){
  f[i] = uex(i);
      }
    }

    break;
  case 2: case 3:
    // Dirichlet (x,y)-Koordinates:
    for(i=0 ; i<NK ; i++){
      if(node[i].id==-2){
    f[i] = XY[2*i+flag-2];
      }
    }
    break;
  }



}
