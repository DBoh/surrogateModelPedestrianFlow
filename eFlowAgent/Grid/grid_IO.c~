void AssignGrid(void (*bound)())
{
  meshgen();             // Gitter erzeugen falls Polygon angegeben wurde
  ScaleGrid();           // Gitter skalieren
  TriangNeighbours();    // Nachbardreiecke berechnen
  RefinementEdge();      // Verfeinerungskanten berechnen
  RefineGrid(bound);     // evtl. Startverfeinerung
  SubDomSetup();         // Teilgebiete fuer Startdichte und variable CV-Werte
  Quadrangulation();     // Datenstruktur zur schnelleren Dreieckssuche
  WallNormal();          // Normalenvektor an der Wand
  InitNeutrals();        // Vektoren mit Nund Einsen, die oft gebraucht werden
  PED.EPS1 = pow(refine.gridwidth,0.2);
}


void ScaleGrid()
{
  int i, l, ll;
  REAL xmax, xmin, ymax ,ymin, dummy, DL;
  char msg[100];


  for(i=0 ; i<NK ; i++){

    if(i==0){
      xmin = XY[2*i]; xmax = xmin;
      ymin = XY[2*i+1]; ymax = ymin;
    } else {

      if(XY[2*i]>xmax)
        xmax = XY[2*i];
      if(XY[2*i]<xmin)
        xmin = XY[2*i];

      if(XY[2*i+1]>ymax)
        ymax = XY[2*i+1];
      if(XY[2*i+1]<ymin)
        ymin = XY[2*i+1];
    }
  }


  refine.boundx_ll = xmin;
  refine.boundx_ur = xmax;
  refine.boundy_ll = ymin;
  refine.boundy_ur = ymax;
  
  refine.scale = refine.boundx_ur-refine.boundx_ll;
  
  if(PED.CL<0) PED.CL = refine.scale;

  //  printf("Domainarea: ll=(%.9e,%.9e), ur=(%.9e,%.9e)\n",refine.boundx_ll,refine.boundy_ll,refine.boundx_ur,refine.boundy_ur);

  // Gitter
  for(i=0 ; i<NK ; i++){

    XY[2*i] -= refine.boundx_ll;
    XY[2*i] /= refine.scale;
    XY[2*i+1] -= refine.boundy_ll;
    XY[2*i+1] /= refine.scale;

  }

  // Messstationen
  for(l=0 ; l<PED.MS ; l++){
    for(ll=0 ; ll<4 ; ll++){
      if(ll%2==0)
        PED.MSx[ll][l] -= refine.boundx_ll;
      else
        PED.MSx[ll][l] -= refine.boundy_ll;
      PED.MSx[ll][l] /= refine.scale;
    }
  }

  // Attraktoren
  for(l=0 ; l<PED.AS ; l++){
    for(ll=0 ; ll<3 ; ll+=2){
      PED.ASx[ll][l] -= refine.boundx_ll;
      PED.ASx[ll][l] /= refine.scale;
      PED.ASx[ll+1][l] -= refine.boundy_ll;
      PED.ASx[ll+1][l] /= refine.scale;
    }
    //    PED.ASx[5][l] /= refine.scale;  // schon beim Einlesen passiert
  }

  // Ausgaenge
  for(l=0 ; l<PED.numexit ; l++){
    for(ll=0 ; ll<3 ; ll+=2){
      PED.exit[ll][l] -= refine.boundx_ll;
      PED.exit[ll][l] /= refine.scale;
      PED.exit[ll+1][l] -= refine.boundy_ll;
      PED.exit[ll+1][l] /= refine.scale;
    }
  }

  // Eingaenge
  for(l=0 ; l<PED.numentree ; l++){
    for(ll=0 ; ll<3 ; ll+=2){
      PED.entree[ll][l] -= refine.boundx_ll;
      PED.entree[ll][l] /= refine.scale;
      PED.entree[ll+1][l] -= refine.boundy_ll;
      PED.entree[ll+1][l] /= refine.scale;
    }
    DL = sqrt(pow(PED.entree[3][l]-PED.entree[1][l],2.)+pow(PED.entree[2][l]-PED.entree[0][l],2.));
    PED.pFlowDoor[l]=fabs(PED.EntreePersons[l])/PED.CT/PED.CP/PED.CV/PED.CL/DL;

  }
  
  // Subdomains
  for(l=0 ; l<SDCV.NumSubdom ; l++){
    for(i=0 ; i<SDCV.P[l].NumK ; i++){
      SDCV.P[l].XY[2*i] -= refine.boundx_ll;
      SDCV.P[l].XY[2*i] /= refine.scale;
      SDCV.P[l].XY[2*i+1] -= refine.boundy_ll;
      SDCV.P[l].XY[2*i+1] /= refine.scale;
    }
  }
    
  
  for(l=0 ; l<RhoIni.NumSubdom ; l++){
    for(i=0 ; i<RhoIni.P[l].NumK ; i++){
      RhoIni.P[l].XY[2*i] -= refine.boundx_ll;
      RhoIni.P[l].XY[2*i] /= refine.scale;
      RhoIni.P[l].XY[2*i+1] -= refine.boundy_ll;
      RhoIni.P[l].XY[2*i+1] /= refine.scale;
    }
  }
  
  refine.boundx_ll = 0;
  refine.boundx_ur = 1;
  refine.boundy_ll = 0;
  refine.boundy_ur = (ymax-ymin)/(xmax-xmin);

  refine.domarea = 0.;
  for(l=0 ; l<NT ; l++)
    refine.domarea += area(l);

#if MSG
  WriteLog("ScaleGrid","a");
  sprintf(msg,"domain-area: %.4f",refine.domarea);
  WriteLog(msg,"a");
#endif
}


void DomainBoundaryGrid()
{
  int k, l, i, count;
  int k0, k1, k2, i11, i12, i21, i22;
  int l0, l1, l2, T1, T2;

  int numd, *Flag;

  numd = 0;
  for(k=0 ; k<NT ; k++){
    tri[k].KindOfBoundary = 0;      // [0,1,2,3] = [inner, bound, exit, entree]
    tri[k].BoundTri[0] = 0;
    
    for(l=0 ; l<3 ; l++){  // wo braucht man das?

      // numd = numdOmega: Anzahl Randkanten
      if(tri[k].NEIGH[l]<0)
	numd++;

      if(node[tri[k].VNR[l]].id<0){
	tri[k].BoundTri[0]++;
	tri[k].BoundTri[tri[k].BoundTri[0]] = l;
      }

      if(tri[k].NEIGH[l]<0)
	{
	  tri[k].KindOfBoundary = 1;
	}

      
      if(ChkExit(tri[k].VNR[(l+1)%3]) || ChkExit(tri[k].VNR[(l+2)%3]))
	tri[k].KindOfBoundary = 2;
      if(PED.numentree && (ChkEntree(tri[k].VNR[(l+1)%3]) || ChkEntree(tri[k].VNR[(l+2)%3])))
	tri[k].KindOfBoundary = 3;
    }
    //    printf("%d ",tri[k].KindOfBoundary);
  }
  //  exit(0);
  refine.numdOmega = numd;
  for(l=0 ; l<4 ; l++)
    refine.dOmega[l] = (int *)calloc(refine.numdOmega , sizeof(int ));
  refine.dOmegaList = (int *)calloc(refine.numdOmega , sizeof(int ));
  refine.dOmegaStartlist = (int *)calloc(refine.numdOmega , sizeof(int ));
  
  Flag = (int *)calloc(refine.numdOmega , sizeof(int ));
  FieldCpInt(refine.dOmegaList,0,refine.dOmegaList,-1,refine.numdOmega);
  
  numd = 0;
  for(k=0 ; k<NT ; k++){
    for(l=0 ; l<3 ; l++){
      if(tri[k].NEIGH[l]<0){
        refine.dOmega[0][numd] = k;
        refine.dOmega[1][numd] = l;
	numd++;
      }
    }
  }

  /*
    refine.dOmega[0][i] = Dreieck an i-ter Kante
    refine.dOmega[1][i] = lokaler Knoten gegenueber i-ter Kante
    refine.dOmega[2][i] = Kantennr vor i-ter Kante
    refine.dOmega[3][i] = Kantennr nach i-ter Kante
  */

  for(k1=0 ; k1<numd ; k1++){
    T1 = refine.dOmega[0][k1];
    l1 = refine.dOmega[1][k1];
    i12 = tri[T1].VNR[(l1+2)%3];
    
    for(k2=0 ; k2<numd ; k2++){
      T2 = refine.dOmega[0][k2];
      l2 = refine.dOmega[1][k2];
      i21 = tri[T2].VNR[(l2+1)%3];

      if(i12==i21){
	refine.dOmega[3][k1] = k2; //T2; // edge above
	refine.dOmega[2][k2] = k1; //T1; // edge before
      }
    }

  }

  /*
    refine.dOmegaListe = sortierte Kantenreihenfolge Ring fuer Ring
    refine.numdOmegaRing = Anzahl geschlossener Ringe
    refine.dOmegaRingliste = Kantennummer der ersten Kante je Ring
   */

  refine.numdOmegaRing=0;
  count=0;
  l0 = 0; // Startkante
  l  = l0;
  refine.dOmegaList[count++] = l;
  refine.dOmegaStartlist[refine.numdOmegaRing++] = l;
  Flag[l0] = 1;
  while(count<refine.numdOmega)
    {
      l = refine.dOmega[3][l];
      if(l!=l0) // Ring noch nicht geschlossen
	{
	  refine.dOmegaList[count++] = l;
	  Flag[l] = 1;
	}
      else  // Ringe geschlossen
	{
	  // eine  noch nicht abgefertigte Randkante
	  for(l=0 ; l<refine.numdOmega ; l++)
	    {
	      if(!Flag[l])
		{
		  refine.dOmegaList[count++] = l;
		  refine.dOmegaStartlist[refine.numdOmegaRing++] = l;
		  break;
		}
	    }
	}
    }


#if PLOT==2
  FILE *fp, *fp2;
  fp=fopen("Octave/dOmega.dat","w");
  k1=0;
  for(i=0 ; i<numd ; i++){
    //    printf("k=%d\n",refine.refine.dOmega[0][i]);
    fprintf(fp,"%d %f %f\n"
            ,k1,XY[2*tri[refine.dOmega[0][k1]].VNR[(refine.dOmega[1][k1]+1)%3]]
	    ,XY[2*tri[refine.dOmega[0][k1]].VNR[(refine.dOmega[1][k1]+1)%3]+1]
	    );

    k1 = refine.dOmega[3][k1];
    
  }
  k1 = 0;
  fprintf(fp,"%d %f %f\n"
	  ,k1,XY[2*tri[refine.dOmega[0][k1]].VNR[(refine.dOmega[1][k1]+1)%3]]
