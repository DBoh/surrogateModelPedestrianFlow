}

void TriangNeighbours()
{
  int k, k2, l, l2, neigh_k, neigh_k2;
  int node1_k, node2_k, node1_k2, node2_k2;

  for(k=0 ; k<NT ; k++)
    for(l=0 ; l<3 ; l++)
      tri[k].NEIGH[l] = -1;

  for(k=0 ; k<NT ; k++){
    for(l=0 ; l<3 ; l++){

      node1_k =  tri[k].VNR[(l+1)%3];
      node2_k =  tri[k].VNR[(l+2)%3];

      for(k2=0 ; k2<NT ; k2++){
        for(l2=0 ; l2<3 ; l2++){

          node1_k2 =  tri[k2].VNR[(l2+1)%3];
          node2_k2 =  tri[k2].VNR[(l2+2)%3];

          if(node1_k2==node2_k && node2_k2==node1_k){

            tri[k].NEIGH[l]   = k2;
            tri[k2].NEIGH[l2] = k;

          }

        }
      }

    }
  }


}




void RefinementEdge()
{
  int k, l, l1, l2, lmax;
  REAL xd, yd, dist, distmax;

  for(k=0 ; k<NT ; k++){
    lmax = 0;
    tri[k].RE = lmax;
    distmax = 0;
    for(l=0 ; l<3 ; l++){
      l1 = tri[k].VNR[(l+1)%3];
      l2 = tri[k].VNR[(l+2)%3];
      xd = XY[2*l1]-XY[2*l2];
      yd = XY[2*l1+1]-XY[2*l2+1];
      dist = sqrt(pow(xd,2.)+pow(yd,2.));
      if(dist>distmax){
        distmax = dist;
        lmax = l;
      }
    }
    tri[k].RE = lmax;
  }


}



void Quadrangulation()
{
  int iq, k, imin, imax, jmin, jmax, l, ll;
  int i0, i1, i2, j0, j1, j2, ij0, ij1, ij2, ij;
  REAL x0, y0, x1, y1, x2, y2;

  QuadN = min(max((int)(1./refine.gridwidth/2),10),100);
  QuadM = min(max((int)(refine.boundy_ur/refine.gridwidth/2),10),100);

  quad = (QUADRA *)malloc(QuadM*QuadN * sizeof(QUADRA ));
  for(iq=0 ; iq<QuadM*QuadN ; iq++){
    quad[iq].Q = (int *)calloc(NT , sizeof( int));
    quad[iq].Qnum = 0;
  }

  for(k=0 ; k<NT ; k++){

    x0 = XY[2*tri[k].VNR[0]];
    y0 = XY[2*tri[k].VNR[0]+1];

    ij0 = X2Quad(x0,y0);
    j0 = ij0%QuadN; i0 = (ij0-j0)/QuadN;

    jmin = j0; jmax = jmin;
    imin = i0; imax = imin;

    x1 = XY[2*tri[k].VNR[1]];
    y1 = XY[2*tri[k].VNR[1]+1];

    ij1 = X2Quad(x1,y1);
    j1 = ij1%QuadN; i1 = (ij1-j1)/QuadN;

    if(j1<jmin) jmin = j1;
    if(j1>jmax) jmax = j1;
    if(i1<imin) imin = i1;
    if(i1>imax) imax = i1;

    x2 = XY[2*tri[k].VNR[2]];
    y2 = XY[2*tri[k].VNR[2]+1];

    ij2 = X2Quad(x2,y2);
    j2 = ij2%QuadN; i2 = (ij2-j2)/QuadN;

    if(j2<jmin) jmin = j2;
    if(j2>jmax) jmax = j2;
    if(i2<imin) imin = i2;
    if(i2>imax) imax = i2;

    for(l=imin ; l<=imax ; l++)
      for(ll=jmin ; ll<=jmax ; ll++){
  ij = l*QuadN+ll;
  quad[ij].Q[quad[ij].Qnum] = k;
  quad[ij].Qnum++;
      }

  }
}


int X2Quad(REAL x, REAL y)
{
  int ii, jj;

  x=max_REAL(0,min_REAL(x,refine.boundx_ur-GridEpsZero));
  y=max_REAL(0,min_REAL(y,refine.boundy_ur-GridEpsZero));

  jj = (int)(x*(QuadN));
  ii = (int)(y*(QuadM/refine.boundy_ur));

  return ii*QuadN+jj;
}



void AttractorMask(int LOOP)
{
  int l, i, kk, ll;
  REAL dd, Px, Py;
  REAL time, oszi, Periode;

  FieldCp(PED.ARMask,0.,PED.ARMask,0.,NK);
  time = LOOP*PED.delta;

  for(i=0 ; i<NK ; i++){
    
    for(l=0 ; l<PED.AS ; l++){
      OrthogonalProjection(&Px,&Py,XY[2*i],XY[2*i+1],PED.ASx[0][l],PED.ASx[1][l],PED.ASx[2][l],PED.ASx[3][l]);
      
      if(!SegBoundarySchnitt(Px,Py,XY[2*i],XY[2*i+1],&kk,&ll))
	{
	  dd = sqrt((Px-XY[2*i])*(Px-XY[2*i])+(Py-XY[2*i+1])*(Py-XY[2*i+1]));
	  oszi = cos(2*PI*PED.ASx[6][l]*time+PED.ASphi[l])*0.5+0.5;
	  PED.ARMask[i] -= oszi*PED.ASx[4][l]*(1.-max_REAL(0.,min_REAL(1.,dd/PED.ASx[5][l])));
	}
    
    }
    PED.ARMask[i] += 1;
  }
#if PLOT
  octaveplot(PED.ARMask,"Mask",0.,2.,LOOP);
#endif

}



