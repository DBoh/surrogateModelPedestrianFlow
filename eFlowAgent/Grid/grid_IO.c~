  ZO.NTones = (REAL *)calloc(NT , sizeof(REAL ));
  ZO.NTzeros = (REAL *)calloc(NT , sizeof(REAL ));

  FieldCp(ZO.NKones,0.,ZO.NKones,1.,NK);
  //  FieldCp(ZO.NKzeros,0.,ZO.NKzeros,0.,NK);
  FieldCp(ZO.NTones,0.,ZO.NTones,1.,NT);
  //  FieldCp(ZO.NTzeros,0.,ZO.NTzeros,0.,NT);

