    fprintf(fp,"%f %f %f\n",XY[2*tri[k].VNR[0]],XY[2*tri[k].VNR[1]],XY[2*tri[k].VNR[2]]);
    fprintf(fp2,"%f %f %f\n",XY[2*tri[k].VNR[0]+1],XY[2*tri[k].VNR[1]+1],XY[2*tri[k].VNR[2]+1]);
