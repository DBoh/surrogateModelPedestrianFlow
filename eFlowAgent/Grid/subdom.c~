void SubDomAttSetup()
{
  int i, k, l, kk, ll;
  REAL dd, ddd, Px, Py;

  /* instead of data-file */
  Att.KnotToSubdom = (int *)calloc(NK , sizeof(int ));
  Att.Kvec = (REAL *)calloc(NK , sizeof(REAL ));
  Att.Tvec = (REAL *)calloc(NT , sizeof(REAL ));

  FieldCp(Att.Kvec,0.,Att.Kvec,1.,NK);
  FieldCp(Att.Tvec,0.,Att.Tvec,1.,NT);

  //test
  REAL aa[2], bb[2];
  
  if(PED.AS){

    for(i=0 ; i<NK ; i++){

      for(l=0 ; l<PED.AS ; l++){ 
	
	OrthogonalProjection(&Px,&Py,XY[2*i],XY[2*i+1],PED.ASx[0][l],PED.ASx[1][l],PED.ASx[2][l],PED.ASx[3][l]);
	/*
	aa[0] = Px - XY[2*i];
	aa[1] = Py - XY[2*i+1];
	bb[0] = PED.ASx[0][l] - PED.ASx[2][l];
	bb[1] = PED.ASx[1][l] - PED.ASx[3][l];
	*/
	
	if(!SegBoundarySchnitt(Px,Py,XY[2*i],XY[2*i+1],&kk,&ll))
	  {
	    dd = sqrt((Px-XY[2*i])*(Px-XY[2*i])+(Py-XY[2*i+1])*(Py-XY[2*i+1]));
	    if(dd<=PED.ASx[5][l]) Att.Kvec[i] = 1-PED.ASx[4][l];
	  }
      }
    }
    
    for(k=0 ; k<NT ; k++){

      Att.Tvec[k] = 0.;
      for(l=0 ; l<3 ; l++)
	Att.Tvec[k] += Att.Kvec[tri[k].VNR[l]]/3.; 
    }

#if PLOT==2
    FILE *fp1, *fp2, *fp3;
    fp1 = fopen("Octave/SubdomAttx.dat","w");
    fp2 = fopen("Octave/SubdomAtty.dat","w");
    fp3 = fopen("Octave/SubdomAttc.dat","w");
    
    for(k=0 ; k<NT ; k++){
      if(fabs(1-Att.Tvec[k])>0){
	fprintf(fp1,"%f %f %f\n",XY[2*tri[k].VNR[0]],XY[2*tri[k].VNR[1]],XY[2*tri[k].VNR[2]]);
	fprintf(fp2,"%f %f %f\n",XY[2*tri[k].VNR[0]+1],XY[2*tri[k].VNR[1]+1],XY[2*tri[k].VNR[2]+1]);
	fprintf(fp3,"%f %f %f\n",Att.Tvec[k],Att.Tvec[k],Att.Tvec[k]);
      }
    }

    fclose(fp1);
    fclose(fp2);
    fclose(fp3);
#endif
  }
}
    

void SubDomFDSetup()
{
  int i, k, l;
  REAL xm, ym, *SDbound[2];
  char linebuf[100];

  /* instead of data-file */
  SDCV.KnotToSubdom = (int *)calloc(NK , sizeof(int ));
  SDCV.Kvec = (REAL *)calloc(NK , sizeof(REAL ));

  FieldCpInt(SDCV.KnotToSubdom,0,SDCV.KnotToSubdom,-1,NK);

  if(strcmp(refine.subdomainFD,"empty")==0){
    for(i=0 ; i<NK ; i++)
      SDCV.Kvec[i] = PED.CV;
  } else {

    FieldCp(SDCV.Kvec,0.,SDCV.Kvec,1.,NK);
    
    for(l=0 ; l<2 ; l++)
      SDbound[l] = (REAL *)calloc(SDCV.PKmax , sizeof(REAL ));
  
    for(i=0 ; i<NK ; i++){
      for(l=0 ; l<SDCV.NumSubdom ; l++){
	for(k=0 ; k<SDCV.P[l].NumK ; k++){
	  SDbound[0][k] = SDCV.P[l].XY[2*k];
	  SDbound[1][k] = SDCV.P[l].XY[2*k+1];
	}
	if(PunktInPolygon(XY[2*i],XY[2*i+1],SDbound,SDCV.P[l].NumK)>=0) SDCV.KnotToSubdom[i]=l;
	if(SDCV.KnotToSubdom[i]>=0)
	  SDCV.Kvec[i] = PED.CVsd[SDCV.KnotToSubdom[i]]/PED.CV;
	
      }
    }
    for(l=0 ; l<2 ; l++)
      free(SDbound[l]);
  }
  
}
    


void SubDomRhoSetup()
{
  int i, k, l, SDmid, i1, i2, ii, count=0;
  REAL Rhom, Rhomin, Rhomax;
  REAL xm, ym, *SDbound[2];
  char linebuf[100];

  RhoIni.KnotToSubdom = (int *)calloc(NK , sizeof(int ));
  RhoIni.Kvec = (REAL *)calloc(NK , sizeof(REAL ));
  RhoIni.Tvec = (REAL *)calloc(NT , sizeof(REAL ));

  FieldCpInt(RhoIni.KnotToSubdom,0,RhoIni.KnotToSubdom,-1,NK);
  
  if(strcmp(refine.subdomainRhoini,"empty")==0){
    FieldCp(RhoIni.Tvec,0.,RhoIni.Tvec,1.,NT);
    FieldCp(RhoIni.Kvec,0.,RhoIni.Kvec,1.,NK);
  } else {

    for(l=0 ; l<2 ; l++)
      SDbound[l] = (REAL *)calloc(RhoIni.PKmax , sizeof(REAL ));

    for(l=0 ; l<RhoIni.NumSubdom ; l++){
      for(k=0 ; k<RhoIni.P[l].NumK ; k++){
	SDbound[0][k] = RhoIni.P[l].XY[2*k];
	SDbound[1][k] = RhoIni.P[l].XY[2*k+1];
      }
      RhoIni.P[l].Area = fabs(PolyArea(SDbound,RhoIni.P[l].NumK));
      
      for(i=0 ; i<NK ; i++){
	if(PunktInPolygon(XY[2*i],XY[2*i+1],SDbound,RhoIni.P[l].NumK)>=0){
	  RhoIni.KnotToSubdom[i]=l;
	  RhoIni.Kvec[i] = 1.;
	  count++;
	}
      }
    }
    
    for(k=0 ; k<NT ; k++)
      for(l=0 ; l<3 ; l++)
	RhoIni.Tvec[k] += RhoIni.Kvec[tri[k].VNR[l]]/3.;
    
    for(l=0 ; l<2 ; l++)
      free(SDbound[l]);

  }


}


