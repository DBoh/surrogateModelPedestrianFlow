/*!
  \brief \(Q\in P\,?\)
  \detail Prueft ob Q im (geschlossenen) Polygonzug P enthalten ist.

  Quelle: https://de.wikipedia.org/wiki/Punkt-in-Polygon-Test_nach_Jordan
*/

int PunktInPolygon(REAL Qx,REAL Qy,REAL *P[2],int N)
{
  REAL t, Ax, Ay, Bx, By, Cx, Cy;
  int i;
  /*
 Parameter: Ecken P[1], ...,P[n] eines ebenen Polygons P, Testpunkt Q
 Rückgabe:  +1, wenn Q innerhalb P liegt;
           −1, wenn Q außerhalb P liegt;
           0, wenn Q auf P liegt
  Setze P[0] = P[n] und t = −1
  Für i = 0, ..., n−1
    Setze t = t * KreuzProdTest(Q,P[i],P[i+1])
    Wenn t = 0
      Abbruch der Schleife
  Ergebnis: t
  */
  t=-1;
  for(i=0 ; i<N-1 ; i++)
    t *= KreuzProdTest(Qx,Qy,P[0][i],P[1][i],P[0][i+1],P[1][i+1]);
  t *= KreuzProdTest(Qx,Qy,P[0][N-1],P[1][N-1],P[0][0],P[1][0]);

  return t;
}

int KreuzProdTest(REAL Ax, REAL Ay, REAL Bx, REAL By, REAL Cx, REAL Cy)
{
  REAL s, delta, eps=GridEpsZero;
  /*
Parameter: Punkte A = (x_A,y_A), B = (x_B,y_B), C = (x_C,y_C)
Rückgabe:  −1, nicht im Polygon;
           0, Punkt auf Kante liegt;
           sonst +1
  Wenn y_B > y_C
    Vertausche B und C
  Wenn y_A ≤ y_B oder y_A > y_C
    Ergebnis: +1
  Setze Delta = (x_B−x_A) * (y_C−y_A) − (y_B−y_A) * (x_C−x_A)  
  Wenn Delta > 0
    Ergebnis: 1
  sonst wenn Delta < 0
    Ergebnis: -1
  sonst
    Ergebnis: 0
  */

  if(By>Cy){
    s=Bx; Bx=Cx; Cx=s;
    s=By; By=Cy; Cy=s;
  }
  if(Ay<=By || Ay>Cy) return 1;
  delta = (Bx-Ax)*(Cy-Ay)-(By-Ay)*(Cx-Ax);
  if(delta>eps) return 1;
  if(delta<-eps) return -1;
  return 0;
}

