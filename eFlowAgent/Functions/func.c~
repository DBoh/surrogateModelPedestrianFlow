}

REAL ExitDistFunc(REAL t, REAL x, REAL y)
{
  int l;
  REAL xydist, dist=-1;

  for(l=0 ; l<PED.numexit ; l++)
    {
      xydist = DistPointLineSegment(x,y,PED.exit[0][l],PED.exit[1][l],PED.exit[2][l],PED.exit[3][l]);
      if(dist<0 || dist>xydist) dist = xydist;
    }
  return dist;
}



