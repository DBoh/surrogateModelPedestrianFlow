//! dist(X,|AB|)
REAL DistPointLineSegment(REAL x, REAL y, REAL ax, REAL ay, REAL bx, REAL by)
{
  REAL t;

  t = (x-ax)*(bx-ax)+(y-ay)*(by-ay);
  t /= (bx-ax)*(bx-ax)+(by-ay)*(by-ay);

  if(t<0)
    return sqrt(pow(x-ax,2.)+pow(y-ay,2.));
  else if(t>1)
    return sqrt(pow(x-bx,2.)+pow(y-by,2.));
  else
    return sqrt(pow(x-ax-t*(bx-ax),2.)+pow(y-ay-t*(by-ay),2.));
}

//! x in a+t(b-a), t in [0,1]?
int PointElementSegment(REAL x1, REAL x2, REAL a1, REAL a2, REAL b1, REAL b2)
{
  REAL normax, normbx, normab;
  REAL epstri = (REAL)GridEpsZero;

  //  EpsSeg *= (REAL)(gridwidth());

  normax=sqrt(pow(a1-x1,2.)+pow(a2-x2,2.));
  normbx=sqrt(pow(b1-x1,2.)+pow(b2-x2,2.));
  normab=sqrt(pow(b1-a1,2.)+pow(b2-a2,2.));
  if(fabs(normab-normax-normbx)<epstri)
    return 1;

  return 0;
}

/*!
  \brief Intersection of two parallel segments
  \detail
  \f[\overline{pq}=\overline{ab}\cap\overline{cd}\f]
  Es ist "IntersectionSegment=true", falls \f$\overline{pq}\neq\emptyset\f$ und dann \f[p=a+t\,(b-a)\,,~q=c+s\,(d-c)\,,\f] sonst "IntersectionSegment=false".

