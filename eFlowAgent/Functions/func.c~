  <td align="center"><img width="500" src="/home/rebekka/pFlow/doc/dox/pics/Functions/IntersecSegment.png"></td>
  </table>
 */
int IntersectionSegment(REAL a1,REAL a2,REAL b1,REAL b2,REAL c1,REAL c2,REAL d1,REAL d2, REAL *p1, REAL *p2, REAL *q1, REAL *q2)
{
  REAL t, s;
  REAL xp1, xp2, xq1, xq2;
  int inseg[4]={0,0,0,0}, bitnum=0;

  *p1=0; *p2=0; *q1=0; *q2=0;

  if(!SegSchnitt(a1,a2,b1,b2,&t,c1,c2,d1,d2,&s)){
    inseg[0] = PointElementSegment(a1,a2,c1,c2,d1,d2);             // a in cd?
    inseg[1] = PointElementSegment(b1,b2,c1,c2,d1,d2);             // b in cd?
    inseg[2] = PointElementSegment(c1,c2,a1,a2,b1,b2);             // c in ab?
    inseg[3] = PointElementSegment(d1,d2,a1,a2,b1,b2);             // d in ab?

    bitnum = inseg[0]*8+inseg[1]*4+inseg[2]*2+inseg[3];

    switch(bitnum){
    case 0: case 1: case 2: case 4: case 5: case 8:
      return 0;
      break;
    case 3: case 7: case 11:// acdb
      *p1=c1; *p2=c2; *q1=d1; *q2=d2;
      break;
    case 6: // acbd
      *p1=c1; *p2=c2; *q1=b1; *q2=b2;
      break;
    case 9: // cadb
      *p1=a1; *p2=a2; *q1=d1; *q2=d2;
      break;
    case 10: case 12: case 13: case 14: case 15: // cabd, a=c & b=d
      *p1=a1; *p2=a2; *q1=b1; *q2=b2;
      break;
    default:
      ErrorMessage("unknown situation","IntersectionSegment");
      break;
    }
    
    if(sqrt(pow(*p1-*q1,2.)+pow(*p2-*q2,2.))<EpsZero) return 0;

    return 1;

  }

  return 0;
}

