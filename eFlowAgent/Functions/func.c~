REAL PolyArea(REAL *P[2], int N)
{
  int k;
  REAL area=0.;
  
  for(k=0 ; k<N ; k++)
    area += determinante(P[0][k],P[1][k],P[0][(k+1)%N],P[1][(k+1)%N]);
  
  return area*0.5;
}


void SetDecomposition(int N, int M, int *Nj)
{
  int k, isum;

  Nj[0] = floor((REAL)N/(REAL)M);
  isum = Nj[0];

  for(k=1 ; k<M-1 ; k++){
    Nj[k] = floor((REAL)(N-isum)/(REAL)(M-k));
    isum += Nj[k];
  }

  if(M>1)
    Nj[M-1] = N-isum;

}


