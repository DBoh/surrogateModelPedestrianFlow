void DiffQuot(REAL *df, REAL *x, REAL *f, int N)
{
  int i;

  df[0]   = (f[1]-f[0])/(x[1]-x[0]);
  df[N-1] = (f[N-1]-f[N-2])/(x[N-1]-x[N-2]);

  for(i=2 ; i<N-1 ; i++)
    df[i] = 0.5*((f[i+1]-f[i])/(x[i+1]-x[i])
     + (f[i]-f[i-1])/(x[i]-x[i-1]));

}

int SegSchnitt(REAL a1,REAL a2,REAL b1,REAL b2,REAL *t,REAL c1,REAL c2,REAL d1,REAL d2,REAL *s)
{
  int out=1;
  REAL epstri = GridEpsZero;
  REAL det;

  det = (b1-a1)*(c2-d2)-(c1-d1)*(b2-a2);

  if(fabs(det)<epstri){
    *t = -1.;
    *s = -1.;
    out=0;
  } else {
    det = 1./det;
    *t = ((c2-d2)*(c1-a1)+(d1-c1)*(c2-a2))*det;
    *s = ((a2-b2)*(c1-a1)+(b1-a1)*(c2-a2))*det;
  }

  if(*t<-epstri || *t>1.+epstri || *s<-epstri || *s>1.+epstri)
    out=0;

  if(fabs(*s)<=epstri) *s=0.;
  if(fabs(*s-1.)<=epstri) *s=1.;
  if(fabs(*t)<=epstri) *t=0.;
  if(fabs(*t-1.)<=epstri) *t=1.;


  return out;
}


/*!
  \brief computes the interseption of two lines

  \f[P=\overline{ab}\cap\overline{cd}=a+t\,(b-a)=c+s\,(d-c)\f]

  \f[{t\choose s}=(b-a,c-d)^{-1}(c-a)\f]
 */
REAL schnitt(REAL a1,REAL a2,REAL b1,REAL b2,REAL c1,REAL c2,REAL d1,REAL d2)
{
  REAL epstri = GridEpsZero; //1.E-10
  REAL det, s, t;

  det = (b1-a1)*(c2-d2)-(c1-d1)*(b2-a2);

  if(fabs(det)<epstri){
    t = -1.;
    s = -1.;
  } else {
    det = 1./det;
    s = ((c2-d2)*(c1-a1)+(d1-c1)*(c2-a2))*det;
    t = ((a2-b2)*(c1-a1)+(b1-a1)*(c2-a2))*det;
  }


  if(fabs(s)<=epstri) s=0.;
  if(fabs(s-1.)<=epstri) s=1.;
  if(fabs(t)<=epstri) t=0.;
  if(fabs(t-1.)<=epstri) t=1.;

  return t;
}


